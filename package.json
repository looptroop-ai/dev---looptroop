{
  "name": "looptroop",
  "version": "1.0.0",
  "description": "",
  "main": "eslint.config.js",
  "scripts": {
    "predev": "tsx scripts/dev-preflight.ts",
    "dev": "tsx scripts/dev.ts",
    "dev:app": "concurrently -n fe,be -c blue,green \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:opencode": "tsx scripts/dev-opencode.ts",
    "dev:frontend": "vite",
    "dev:backend": "CHOKIDAR_USEPOLLING=1 tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:client": "vitest run --project client",
    "test:server": "vitest run --project server-unit",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liviux/test-sonnet.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/liviux/test-sonnet/issues"
  },
  "homepage": "https://github.com/liviux/test-sonnet#readme",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@hono/node-server": "^1.19.9",
    "@opencode-ai/sdk": "^1.2.22",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.12.3",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
